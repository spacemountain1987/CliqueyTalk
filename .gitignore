# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Next.js build output
/.next/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Firebase
.firebase/
firebase-debug.log

# Google Cloud Service Account Keys
# IMPORTANT: Never commit service account keys.
**/service-account*.json
**/*serviceaccount*.json
**/firebase-adminsdk-*.json
**/*credentials*.json

# Do NOT ignore all JSON files. This repo needs JSON config checked in
# (e.g. package.json / tsconfig.json). If you need local-only JSON,
# add it explicitly here.

# VSCode settings
.vscode/
