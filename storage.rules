rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow reads for signed-in users only for app audio assets.
    match /soundboard/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /queued-songs/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
