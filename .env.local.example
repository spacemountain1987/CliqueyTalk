# Local development example configuration
# Copy to .env.local and fill values.
# Do NOT commit .env.local.

# Optional (used to build OAuth redirect URLs). If unset, routes use request origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# If you want to use Secret Manager locally, you need ADC and should set:
# USE_SECRET_MANAGER=true
# GCP_PROJECT=your-gcp-project-id

# Fast local fallback (no ADC): set secrets directly as env vars.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_PUBLIC_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_COOKIE=
